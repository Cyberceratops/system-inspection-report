# Copy this file to a root-only environment file, for example:
#   /etc/system-inspection-report.env
# Never commit real secrets.

REPORT_TZ=Asia/Shanghai
REPORT_DIR=/var/log/system-inspection-reports
SYSTEM_INSPECTION_CONFIG=/etc/system-inspection-report.json

# Optional: force a specific network interface. Leave empty to auto-select a non-Docker interface.
REPORT_NET_IFACE=

# Delivery is disabled by default in the open-source template.
SEND_EMAIL=0
SEND_TELEGRAM=0
DELIVERY_MODE=best-effort
RECIPIENT=root

# Telegram credentials. Keep the real file chmod 600 and owned by root.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
